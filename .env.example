DATABASE_URL=postgresql://assetflow:assetflow@localhost:5432/asset_flow?schema=public
JWT_SECRET=asset-flow-dev-secret-change-in-production
PORT=3001

# 前端来源，多个用逗号分隔（CORS）
# 本地: http://localhost:5173
# Railway: https://your-web-service.up.railway.app
WEB_ORIGIN=http://localhost:5173

# 前端构建时注入（仅 Railway Web 服务需要）
VITE_API_BASE_URL=

# 强制重新 seed（默认已有数据会跳过）
FORCE_SEED=false
